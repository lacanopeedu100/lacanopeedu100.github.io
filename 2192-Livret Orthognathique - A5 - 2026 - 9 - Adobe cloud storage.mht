@media (max-width: 414px) and (max-height: 610px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainerMnm .adbmsgContentIframeMnm { border-radius: 0px; }
}

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer.adbmsgContentContainerMaximised { height: 90vh; left: 5%; min-height: 580px; min-width: 380px; top: 5%; width: 90vw; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer.adbmsgContentContainerMaximised .adbmsgContentHeader { cursor: default; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer.assistantUiMinimised { height: 780px; }

@media (min-width: 480px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer.assistantUiMinimised { min-width: 480px; }
}

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer { background-color: rgb(245, 245, 245); border-radius: 8px; bottom: 40px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; box-sizing: border-box; direction: ltr; display: none; height: 580px; max-height: 90%; max-width: 95%; overflow: auto; position: fixed; right: 40px; z-index: 9999999; }

@media (min-width: 380px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainer { min-width: 380px; }
}

