.adbMsgClientWrapper #adbmsgContainer *, .adbMsgClientWrapper #adbmsgContainer ::after, .adbMsgClientWrapper #adbmsgContainer ::before { box-sizing: border-box; }

.adbMsgClientWrapper #adbmsgContainer .outwardAnimate { animation-duration: 0.3s; animation-name: outwardmove; animation-timing-function: cubic-bezier(0, 0, 0.4, 1); transition: opacity 0.3s; }

@keyframes outwardmove { 
  0% { opacity: 0; transform: scale(0.83); }
  100% { opacity: 1; transform: scale(1); }
}

@-webkit-keyframes outwardmove { 
  0% { opacity: 0; transform: scale(0.83); }
  100% { opacity: 1; transform: scale(1); }
}

.adbMsgClientWrapper #adbmsgContainer .adbmsgCtaDarkest { background-color: rgb(29, 29, 29) !important; background-image: url("assets/cta_darkest.svg") !important; border: 2px solid rgb(219, 219, 219) !important; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCtaDarkest:hover { border-color: rgb(242, 242, 242) !important; }

.adbMsgClientWrapper #adbmsgContainer .botauthorCta { background-image: url("assets/botAvatar.svg") !important; background-position-y: 0px !important; background-size: 60px !important; border: 0px !important; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta { background-color: rgb(255, 255, 255); background-image: url("assets/cta.svg"); background-position: center 18px; background-repeat: no-repeat; background-size: 24px; border: 2px solid rgb(41, 41, 41); border-radius: 60px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; color: rgb(52, 73, 94); cursor: pointer; display: none; font-size: 20px; height: 60px; margin: 0px auto; outline: none; overflow: visible; padding: 0px; position: fixed; text-align: center; text-decoration: none; vertical-align: middle; width: 60px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta .adbmsg-tooltip { background: rgb(118, 118, 118); border: 2px solid rgb(118, 118, 118); border-radius: 4px; bottom: 60px; color: rgb(255, 255, 255); cursor: text; display: none; font-size: 12px; line-height: 15px; margin: 0px; max-width: 200px; min-width: 80px; padding: 2.5px 3px; position: absolute; right: -12px; user-select: text; font-weight: 400 !important; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta .adbmsg-tooltip::before { border-color: rgb(118, 118, 118) transparent; border-style: solid; border-width: 4px 4px 0px; bottom: -6px; content: ""; position: absolute; right: 34px; width: 8px; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta .adbmsg-tooltip::after { border-color: rgb(118, 118, 118) transparent; border-style: solid; border-width: 4px 4px 0px; bottom: -5px; content: ""; position: absolute; right: 34px; width: 8px; }

@media (min-width: 460px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgCta { bottom: 40px; right: 40px; }
  .adbMsgClientWrapper #adbmsgContainer .adbmsgAEPInvitationPopUpContainer { right: 40px !important; }
}

@media (min-width: 415px) and (max-width: 459px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgCta { bottom: 40px; right: 10px; }
  .adbMsgClientWrapper #adbmsgContainer .adbmsgAEPInvitationPopUpContainer { right: 10px !important; }
}

@media (max-width: 414px) {
  .adbMsgClientWrapper #adbmsgContainer .adbmsgCta { bottom: 20px; right: 20px; }
  .adbMsgClientWrapper #adbmsgContainer .adbmsgAEPInvitationPopUpContainer { right: 20px !important; }
}

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta.focus-ring:focus { border-color: rgb(84, 155, 239) !important; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCta .adbmsgbadge { background-color: rgb(236, 91, 98); border: 2px solid rgb(255, 255, 255); border-radius: 22px; color: rgb(255, 255, 255); font-size: 10px; font-weight: 700; height: 18px; line-height: 20px; position: absolute; right: 0px; top: -1px; width: 18px; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgCustombadge { border: 0px !important; }

.adbMsgClientWrapper #adbmsgContainer .upwardAnimate { animation-duration: 0.3s; animation-name: upwardmove; animation-timing-function: cubic-bezier(0, 0, 0.4, 1); transition: opacity 0.3s; }

@keyframes upwardmove { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@-webkit-keyframes upwardmove { 
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.adbMsgClientWrapper #adbmsgContainer .downwardAnimate { animation-duration: 0.3s; animation-name: downwardmove; animation-timing-function: cubic-bezier(0, 0, 0.4, 1); transition: opacity 0.3s; }

@keyframes downwardmove { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

@-webkit-keyframes downwardmove { 
  0% { opacity: 1; }
  100% { opacity: 0; }
}

.adbMsgClientWrapper #adbmsgContainer .adbmsgEngagementPopUpContainer { background-repeat: no-repeat; background-size: 100% 100%; border-radius: 8px; bottom: 148px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; box-sizing: border-box; display: none; min-height: 236px; position: fixed; right: 40px; width: 363px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgEngagementPopUpContainerJarvisTheme { background-color: rgb(67, 84, 204); padding: 12px; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgEngagementPopUpContainerBackground { background-color: rgb(255, 255, 255); padding: 16px 40px 40px 17px; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgTutorialPopUpContainer { background-color: rgb(67, 84, 204); background-repeat: no-repeat; background-size: 100% 100%; border-radius: 8px; bottom: 30px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; box-sizing: border-box; display: none; height: 261px; min-height: 236px; padding: 21px 16px 22px 21px; position: fixed; right: 40px; width: 434px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgAuthoredBotPopUpContainer { background:  0% 0% / 100% 100% no-repeat rgb(255, 255, 255); border: 1px solid rgb(211, 211, 211); border-radius: 8px; box-sizing: border-box; display: none; height: 52px; padding: 0px 2px 14px 17px; position: fixed; right: 110px; width: 311px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgAutoRenewalPopUpContainer { background-color: rgb(67, 84, 204); background-repeat: no-repeat; background-size: 100% 100%; border-radius: 8px; bottom: 30px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; box-sizing: border-box; display: none; height: 205px; padding: 21px 16px 22px 21px; position: fixed; right: 40px; width: 374px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainerMnm { background-color: rgb(236, 91, 98); border-radius: 8px; bottom: 40px; box-shadow: rgba(0, 0, 0, 0.15) 0px 2px 4px; box-sizing: border-box; direction: ltr; display: none; height: 580px; position: fixed; right: 40px; width: 380px; z-index: 9999999; }

.adbMsgClientWrapper #adbmsgContainer .adbmsgContentContainerMnm .wait-wrapper { inset: 0px; height: 32px; margin: auto; position: absolute; width: 32px; }

